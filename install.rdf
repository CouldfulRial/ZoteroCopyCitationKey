<?xml version="1.0" encoding="UTF-8"?>
<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:em="http://www.mozilla.org/2004/em-rdf#">
  <Description about="urn:mozilla:install-manifest">
    <em:id>copy-citation-key@example.com</em:id>
    <em:name>Copy Citation Key</em:name>
    <em:version>1.0.4</em:version>
    <em:type>2</em:type>
    <em:bootstrap>true</em:bootstrap>
    <em:description>Copy citation key(s) from selected Zotero items with Cmd/Ctrl+C</em:description>
    <em:creator>yifangong</em:creator>
    <em:targetApplication>
      <Description>
        <em:id>zotero@chnm.gmu.edu</em:id>
        <em:minVersion>6.999</em:minVersion>
        <em:maxVersion>8.*</em:maxVersion>
      </Description>
    </em:targetApplication>
  </Description>
</RDF>
